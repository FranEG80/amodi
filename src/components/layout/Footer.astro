---
import { Mail, MapPin, Phone } from 'lucide-astro';

interface FooterLink {
  label: string;
  href?: string;
  pending?: boolean;
}

interface Props {
  brand: {
    logo: {
      src: string;
      alt: string;
      width: number;
      height: number;
    };
  };
  footer: {
    copyright: string;
    links: FooterLink[];
  };
  contact: {
    address: { label: string; value: string; href?: string };
    email: { label: string; value: string; href: string };
    phone: { label: string; value: string; href: string };
  };
  uiLabels: {
    footerNavigation: string;
    contactList: string;
  };
}

const { brand, footer, contact, uiLabels } = Astro.props;
const contactItems = [
  { ...contact.address, Icon: MapPin },
  { ...contact.email, Icon: Mail },
  { ...contact.phone, Icon: Phone }
];
