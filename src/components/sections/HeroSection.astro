---
import Button from '../ui/Button.astro';

interface Props {
  hero: {
    title: string;
    subtitle: string;
    primaryCta: { label: string; href: string };
    secondaryCta: { label: string; href: string };
    image: {
      src: string;
      alt: string;
      width: number;
      height: number;
    };
  };
  mainMessage: string;
}

const { hero, mainMessage } = Astro.props;
const [featuredWord, ...restTitle] = hero.title.split(' ');
---

<section id="inicio" class="relative isolate min-h-[calc(100svh-5rem)] overflow-hidden bg-slate-950">
  <img
    src={hero.image.src}
    alt={hero.image.alt}
    width={hero.image.width}
    height={hero.image.height}
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    fetchpriority="high"
    loading="eager"
    decoding="sync"
  />
  <!-- linear-gradient(90deg,rgba(255,255,255,0.96)_0%,rgba(255,255,255,0.88)_20%,rgba(255,255,255,0.35)_40%,rgba(7,16,51,0.16)_60%) -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(255,255,255,0.80)_0%,rgba(255,255,255,0.9)_20%,rgba(255,255,255,0.5)_50%,rgba(255,255,255,0.7)_100%)]  sm:bg-[linear-gradient(90deg,rgba(255,255,255,0.7)_0%,rgba(255,255,255,0.6)_20%,rgba(255,255,255,0.5)_50%,rgba(255,255,255,0.3)_80%)] lg:bg-[linear-gradient(90deg,rgba(255,255,255,0.80)_0%,rgba(255,255,255,0.75)_20%,rgba(255,255,255,0.35)_50%,rgba(7,16,51,0)_80%)] "></div>
  <div aria-hidden="true" class="absolute inset-x-0 bottom-0 -z-10 h-28 bg-gradient-to-t from-white to-transparent"></div>

  <div class="mx-auto flex min-h-[calc(100svh-5rem)] w-full container items-center px-4 py-20 pt-0 sm:px-6 lg:px-8">
    <div class="max-w-7xl">
      <p class="inline-flex rounded-full border border-white/80 bg-white/80 px-4 py-2 text-sm font-black text-brand-blue shadow-soft backdrop-blur-md">
        {mainMessage}
      </p>
      <h1 class="font-display-script hero-title-script mt-20 max-w-7xl text-center sm:text-inherit text-balance text-8xl leading-[0.82] text-brand-ink sm:text-8xl lg:text-9xl">
        <span class="hero-rainbow-title">{featuredWord}</span>
        {' '}
        <span class="block text-brand-ink">
          <span class="inline-flex items-end self-start">
            {restTitle.join(' ')}
            <svg fill="none" aria-hidden="true" class="size-20 shrink-0  scale-75 text-white sm:size-20 lg:size-24 -translate-x-8 -translate-y-3 rotate-33" viewBox="0 0 96 96"><defs><linearGradient id="rainbow-heart" x1="0" x2="96" y1="0" y2="96" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#ef4444"/><stop offset="18%" stop-color="#f97316"/><stop offset="34%" stop-color="#facc15"/><stop offset="50%" stop-color="#22c55e"/><stop offset="66%" stop-color="#06b6d4"/><stop offset="82%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#a855f7"/></linearGradient></defs><path stroke="url(#rainbow-heart)" stroke-linecap="round" stroke-linejoin="round" stroke-width="9.2" d="M49.2 81.8C30.8 68.9 14 54.4 14 35.2c0-9.4 6.1-16.9 14.5-16.9 6.8 0 11.9 4.3 15.2 10 3.7-6.2 9.5-10.1 16.2-10.1C68.3 18.2 74 25 74 34.5c0 17.7-13.5 29.7-24.8 47.3"/></svg>
          </span>
        </span>
      </h1>
      <div class="mt-14 flex flex-col gap-3 sm:flex-row">
        <Button href={hero.primaryCta.href} label={hero.primaryCta.label} />
        <Button href={hero.secondaryCta.href} label={hero.secondaryCta.label} variant="secondary" icon="calendar" />
      </div>
      <p class="mt-9 max-w-4xl text-pretty text-lg font-medium leading-8 text-slate-800 sm:text-xl lg:max-w-2xl">
        {hero.subtitle}
      </p>
    </div>
  </div>
</section>

<style>
  .hero-horizontal-gradient {
    background: linear-gradient(
      90deg,
      rgb(255 255 255 / 0.92) 0%,
      rgb(255 255 255 / 0.84) 42%,
      rgb(255 255 255 / 0.68) 72%,
      rgb(255 255 255 / 0.52) 100%
    );
  }

  @media (min-width: 64rem) {
    .hero-horizontal-gradient {
      background: linear-gradient(
        90deg,
        rgb(255 255 255 / 0.8) 0%,
        rgb(255 255 255 / 0.75) 20%,
        rgb(255 255 255 / 0.35) 40%,
        rgb(7 16 51 / 0.16) 60%
      );
    }
  }
</style>
