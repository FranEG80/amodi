---
import { CheckCircle2 } from 'lucide-astro';
import NewsCard from '../ui/NewsCard.astro';
import PosterDialog from '../ui/PosterDialog.astro';
import SectionTitle from '../ui/SectionTitle.astro';

interface PosterImage {
  src: string;
  alt: string;
  width: number;
  height: number;
}

interface NewsItem {
  title: string;
  text: string;
  poster?: PosterImage;
  action?: {
    label: string;
    href: string;
  };
}

interface Props {
  news: {
    title: string;
    items: NewsItem[];
    debate: {
      title: string;
      items: string[];
    };
  };
  membershipPoster: PosterImage;
}

const { news, membershipPoster } = Astro.props;
const bentoSpans = [
  'lg:col-span-5',
  'lg:col-span-7',
  'lg:col-span-7',
  'lg:col-span-5'
];
---

<section id="noticias" class="section-pad bg-soft ">
  <div class="mx-auto container px-4 sm:px-6 lg:px-8">
    <SectionTitle title={news.title} />
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-12">
      {news.items.map((item, index) => (
        <div class:list={['min-w-0', bentoSpans[index] ?? 'lg:col-span-6']}>
          <NewsCard
            id={`item-${index + 1}`}
            title={item.title}
            text={item.text}
            poster={item.poster}
            action={item.action}
          />
        </div>
      ))}
    </div>
    <div class="mt-8 grid gap-5 lg:grid-cols-12 lg:items-stretch">
      <article class="rounded-2xl border border-slate-100 bg-soft p-6 shadow-rainbow sm:p-8 lg:col-span-8">
        <h3 class="text-2xl font-black text-slate-950">{news.debate.title}</h3>
        <ul class="mt-6 grid gap-4 md:grid-cols-2">
          {news.debate.items.map((item) => (
            <li class="flex gap-3 text-sm leading-7 text-slate-700">
              <CheckCircle2 aria-hidden="true" class="mt-1 size-5 shrink-0 text-brand-green" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </article>

      <article class="rounded-2xl border border-slate-100 bg-white p-5 shadow-soft lg:col-span-4">
        <PosterDialog
          id="asociate-amodi-actualidad"
          title="Asóciate a AMODI"
          poster={membershipPoster}
          class="h-full w-full"
          imageClass="aspect-square object-cover object-top"
        />
      </article>
    </div>
  </div>
</section>
