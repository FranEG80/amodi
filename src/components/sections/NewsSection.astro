---
import { CheckCircle2 } from 'lucide-astro';
import NewsCard from '../ui/NewsCard.astro';
import SectionTitle from '../ui/SectionTitle.astro';

interface NewsItem {
  title: string;
  text: string;
}

interface Props {
  news: {
    title: string;
    items: NewsItem[];
    debate: {
      title: string;
      items: string[];
    };
  };
}

const { news } = Astro.props;
---

<section id="noticias" class="section-pad bg-soft ">
  <div class="mx-auto container px-4 sm:px-6 lg:px-8">
    <SectionTitle title={news.title} />
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {news.items.map((item) => (
        <NewsCard title={item.title} text={item.text} />
      ))}
    </div>
    <article class="mt-8 rounded-lg border border-slate-100 bg-soft p-6 shadow-rainbow sm:p-8">
      <h3 class="text-2xl font-black text-slate-950">{news.debate.title}</h3>
      <ul class="mt-6 grid gap-4 md:grid-cols-2 ">
        {news.debate.items.map((item) => (
          <li class="flex gap-3 text-sm leading-7 text-slate-700">
            <CheckCircle2 aria-hidden="true" class="mt-1 size-5 shrink-0 text-brand-green" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>
  </div>
</section>
