---
import { ExternalLink, Music2 } from 'lucide-astro';
import PosterDialog from './PosterDialog.astro';

interface PosterImage {
  src: string;
  alt: string;
  width: number;
  height: number;
}

interface Props {
  id: string;
  title: string;
  text: string;
  poster?: PosterImage;
  action?: {
    label: string;
    href: string;
  };
}

const { id, title, text, poster, action } = Astro.props;
---

<article
  class:list={[
    'grid h-full overflow-hidden rounded-2xl border border-slate-100 bg-white p-5 shadow-soft',
    poster && 'gap-5 sm:grid-cols-[10.5rem_1fr] sm:items-stretch'
  ]}
>
  {poster && (
    <PosterDialog
      id={`news-${id}`}
      title={title}
      poster={poster}
      class="mx-auto w-full max-w-52 sm:mx-0 sm:h-full sm:max-w-none"
      imageClass="aspect-square object-cover object-top sm:h-full sm:min-h-44"
    />
  )}
  <div class="flex flex-col justify-center">
    <h3 class="text-xl font-black leading-tight text-slate-950">{title}</h3>
    <p class="mt-4 text-sm leading-7 text-slate-700">{text}</p>
    {action && (
      <a
        href={action.href}
        target="_blank"
        rel="noopener noreferrer"
        class="focus-ring mt-6 inline-flex min-h-11 w-fit items-center gap-2 rounded-full bg-[#1ed760] px-5 py-3 text-sm font-black text-slate-950 transition duration-200 hover:-translate-y-0.5 hover:bg-[#1fdf64] motion-reduce:transform-none"
      >
        <Music2 aria-hidden="true" class="size-5" />
        <span>{action.label}</span>
        <ExternalLink aria-hidden="true" class="size-4" />
      </a>
    )}
  </div>
</article>
