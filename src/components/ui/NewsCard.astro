---
interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
---

<article class="rounded-lg border border-slate-100 bg-white p-6 shadow-soft">
  <h3 class="text-xl font-black leading-tight text-slate-950">{title}</h3>
  <p class="mt-4 text-sm leading-7 text-slate-700">{text}</p>
</article>
