---
import { MapPin } from 'lucide-astro';
import PosterDialog from './PosterDialog.astro';

interface PosterImage {
  src: string;
  alt: string;
  width: number;
  height: number;
}

interface Props {
  id: string;
  date: string;
  day: string;
  month: string;
  fullDate: string;
  title: string;
  place: string;
  time: string;
  description: string;
  label_color?: string;
  poster?: PosterImage;
}

const { id, date, day, month, fullDate, title, place, time, description, label_color, poster } = Astro.props;

---

<article id={id} class="grid scroll-mt-28 gap-4 rounded-lg border border-slate-100 bg-white p-5 shadow-soft sm:grid-cols-[5.5rem_1fr]">
  <div class="flex h-20 w-20 items-center justify-center rounded-lg bg-slate-50 text-center shadow-inner">
    <time datetime={date} class="grid gap-1">
      <span class={`bg-clip-text text-3xl font-black leading-none ${label_color}`}>{day}</span>
      <span class="text-sm font-black uppercase text-slate-950">{month}</span>
    </time>
  </div>
  <div class="min-w-0">
    <div class="flex flex-nowrap flex-col sm:flex-row items-center justify-between gap-2">
      <div >
        <h3 class="text-lg font-black leading-snug text-slate-950">{title}</h3>
        <p class="mt-2 text-sm font-black text-brand-violet">{fullDate} · {time}</p>
        <p class="mt-1 mb-2.5 flex  items-start gap-1 text-xs font-bold text-slate-700">
          <MapPin aria-hidden="true" class="mt-0.5 size-3 shrink-0 text-brand-pink" />
          <span>{place}</span>
        </p>
        <p class=" text-sm  text-slate-700">{description}</p>
      </div>
      {poster && (
        <PosterDialog
          id={`${id}-poster`}
          title={title}
          poster={poster}
          class="mt-5 w-[55%] sm:max-w-40"
          imageClass="aspect-square object-cover object-top"
        />
      )}
    </div>
  </div>
</article>
