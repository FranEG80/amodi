---
interface Props {
  title: string;
  text?: string;
  align?: 'left' | 'center';
}

const { title, text, align = 'center' } = Astro.props;
const alignment = align === 'left' ? 'items-start text-left' : 'items-center text-center';
---

<div class:list={['flex flex-col gap-4', alignment]}>
  <span aria-hidden="true" class="h-1.5 w-28 rounded-full bg-rainbow"></span>
  <h2 class="max-w-4xl text-balance text-3xl font-black leading-tight text-slate-950 sm:text-4xl lg:text-5xl">
    {title}
  </h2>
  {text && (
    <p class="max-w-3xl text-pretty text-base leading-8 text-slate-700 sm:text-lg">
      {text}
    </p>
  )}
</div>
