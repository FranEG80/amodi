---
import AboutSection from '../components/sections/AboutSection.astro';
import EventsSection from '../components/sections/EventsSection.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import NewsSection from '../components/sections/NewsSection.astro';
import ParticipationSection from '../components/sections/ParticipationSection.astro';
import PrideSection from '../components/sections/PrideSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../data/content.json';
---

<BaseLayout>
  <HeroSection hero={content.hero} mainMessage={content.brand.mainMessage} />
  <AboutSection about={content.about} services={content.services} />
  <PrideSection pride={content.pride} events={content.events} />
  <EventsSection events={content.events} />
  <NewsSection news={content.news} membershipPoster={content.participation.poster} />
  <ParticipationSection participation={content.participation} contact={content.contact} socials={content.socials} />
</BaseLayout>
